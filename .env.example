# External PostgreSQL connection used by the runner container.
# If PostgreSQL runs on the Docker host, host.docker.internal works out of the box
# because docker-compose.yml maps it to host-gateway for the runner service.
DATABASE_URL=postgresql://runner:runner@host.docker.internal:5432/flow-runner

# Optional runtime tuning
RUNNER_LOG=info

# Published host port for both the frontend and runner API
RUNNER_PORT=6302

# AI Provider Configuration for Claude Agent SDK
# Base URL for the AI API (optional, defaults to Anthropic's official API)
ANTHROPIC_BASE_URL=https://api.siliconflow.cn

# Authentication token for the AI API (required)
ANTHROPIC_AUTH_TOKEN=sk-xxx

# Model identifier to use (optional, defaults to SDK's default model)
# Examples:
#   - Anthropic: claude-sonnet-4-6, claude-opus-4-7
#   - SiliconFlow: Pro/zai-org/GLM-5.1
ANTHROPIC_MODEL=Pro/zai-org/GLM-5.1

# Optional AI gateway host/port
AI_GATEWAY_HOST=127.0.0.1
AI_GATEWAY_PORT=3000
