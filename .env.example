# External PostgreSQL connection used by the backend container.
# If PostgreSQL runs on the Docker host, host.docker.internal works out of the box
# because docker-compose.yml maps it to host-gateway for the backend service.
DATABASE_URL=postgresql://runner:runner@host.docker.internal:5432/flow-runner

# Optional backend runtime tuning
BACKEND_LOG=info

# Published host ports
BACKEND_PORT=6302
AI_GATEWAY_PORT=6307
HELLO_WORLD_PLUGIN_PORT=9101

# Optional: auto-register HTTP plugins when backend starts.
# Multiple plugin base URLs can be separated with commas.
# Example:
# BACKEND_AUTO_REGISTER_PLUGIN_URLS=http://127.0.0.1:9101
BACKEND_AUTO_REGISTER_PLUGIN_URLS=

# Optional: override the Claude Code executable inside ai-gateway container
# CLAUDE_CODE_EXECUTABLE=/usr/local/bin/claude
