# External PostgreSQL connection used by the runner container.
# If PostgreSQL runs on the Docker host, host.docker.internal works out of the box
# because docker-compose.yml maps it to host-gateway for the runner service.
DATABASE_URL="postgresql://admin:admin%40123456@47.100.210.56:5432/flow-runner"

# Optional runtime tuning
RUNNER_LOG=info

# Optional SigNoz/OpenTelemetry tracing.
SIGNO_UI=http://192.168.110.45:7380
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://192.168.110.45:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_SERVICE_NAMESPACE=ses-flow
OTEL_DEPLOYMENT_ENVIRONMENT=dev

# Published host port for both the frontend and runner API
RUNNER_PORT=6302

# 旧版本的 MongoDB 连接字符串，已废弃
MONGODB_WES_URL=mongodb://admin:123456@192.168.130.169:27017/hyperleap_wes

# MONGODB_RCS_URL=mongodb://admin:123456@192.168.130.169:27017/sorting_db

RUNNER_BASE_URL=http://127.0.0.1:6302/runner-api