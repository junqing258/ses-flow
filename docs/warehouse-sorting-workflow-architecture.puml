@startuml

!include https://md-1301452398.cos.ap-nanjing.myqcloud.com/orchard/c4_plantuml/core.puml

title Warehouse Sorting Workflow Platform - Recommended Architecture

skinparam componentStyle rectangle
skinparam shadowing false

package "Frontend" {
  [Workflow Designer\n(Vue 3 + Vue Flow)] as FE_DESIGN
  [Ops Console] as FE_OPS
  [Task Workbench\n(PDA / Station)] as FE_TASK
  [Rule & Connector Admin] as FE_ADMIN
}

package "API Layer" {
  [API Gateway / BFF] as API
}

package "Core Services" {
  [Workflow Definition Service] as DEF
  [Workflow Engine Service\n(Node.js Runner)] as ENG
  [Task Service] as TASK
  [Connector Gateway] as CONN
  [Rule Service] as RULE
  [Observability & Audit] as OBS
}

package "Engine Internals" {
  [Definition Loader] as E1
  [Execution Orchestrator] as E2
  [Transition Resolver] as E3
  [Executor Registry] as E4
  [State Manager] as E5
  [Waiting Manager] as E6
  [Idempotency Guard] as E7
}

database "PostgreSQL" as DB
collections "Redis" as REDIS
queue "Message Bus" as MQ
cloud "External Systems\nOMS/WMS/RCS/Printer/Label" as EXT

FE_DESIGN --> API
FE_OPS --> API
FE_TASK --> API
FE_ADMIN --> API

API --> DEF
API --> ENG
API --> TASK
API --> RULE
API --> CONN
API --> OBS

ENG --> E1
ENG --> E2
ENG --> E3
ENG --> E4
ENG --> E5
ENG --> E6
ENG --> E7

DEF --> DB
RULE --> DB
TASK --> DB
OBS --> DB
ENG --> DB

ENG --> REDIS
TASK --> REDIS
CONN --> REDIS

ENG --> MQ
TASK --> MQ
CONN --> MQ

CONN --> EXT
TASK --> EXT

EXT --> API : webhook/callback
MQ --> ENG : resume event
TASK --> ENG : task status callback
RULE --> ENG : rule evaluation
DEF --> ENG : published definition
OBS --> FE_OPS : timeline/query
@enduml
