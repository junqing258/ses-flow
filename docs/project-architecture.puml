' ============================================================
' Diagram 1: Container Diagram
' ============================================================
@startuml ses-flow-containers

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_WITH_LEGEND()

title SES Flow — Container Diagram

Person(user, "用户 / 开发者", "在浏览器中编辑工作流、触发运行、查看结果")

System_Boundary(ses, "SES Flow Monorepo") {

    Container(frontend, "Frontend SPA", "Vue 3 + Vite\napps/frontend", "工作流可视化编辑器，运行监控面板")

    Container(backend, "Backend Service", "Rust + Axum\napps/backend  :6302", "统一对外入口：静态资源托管 / REST API / SSE / 登录认证 /AI 代理")

    Container(runner_lib, "Runner Library", "Rust crate\napps/runner", "嵌入 backend 进程，负责工作流调度与执行；\n含 WorkflowApp / WorkflowEngine / Executors\n并发控制（ConcurrencyGate）")

    Container(ai_gateway, "AI Gateway", "Node.js + Express\napps/ai-gateway  :6307", "管理 Claude AI 会话、SSE 事件流、工具权限")

    ContainerDb(postgres, "PostgreSQL", "数据库", "存储工作流 catalog、运行记录、编辑 session、运行快照")
}

System_Ext(claude_sdk, "Claude Agent SDK", "Anthropic AI Agent，受限工具调用")
System_Ext(node_proc, "Node.js / Rust 子进程", "code executor 按需拉起（JS/TS 用 Node.js，Rust 用 rustc 编译后执行）")

Rel(user, frontend, "编辑工作流 / 查看运行结果", "HTTPS")
Rel(frontend, backend, "工作流 CRUD / 触发运行 / SSE 订阅", "HTTP /runner-api")
Rel(frontend, backend, "AI 协作消息 / 事件流", "HTTP /api/ai/*")
Rel(backend, frontend, "托管 SPA 静态资源", "ServeDir /views")
Rel(backend, ai_gateway, "反向代理 AI 请求", "HTTP /api/ai/* → :6307")
Rel(ai_gateway, backend, "回调读写 edit session / preview", "HTTP /runner-api")
Rel(ai_gateway, claude_sdk, "调用 Claude Agent SDK", "HTTPS API")
Rel(backend, runner_lib, "调用（库函数，同进程）", "in-process")
Rel(runner_lib, postgres, "读写 catalog / 运行记录 / edit session / 快照", "SQL via sqlx")
Rel(runner_lib, node_proc, "code 节点：fork 子进程", "stdin/stdout")

@enduml


' ============================================================
' Diagram 2: Component Diagram — Runner 节点设计
' ============================================================
@startuml ses-flow-node-design

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()

title SES Flow — Runner 节点执行设计（C4 Component Diagram）

' ── 外部调用方 ──────────────────────────────────────────────
Container_Ext(backend_api, "Backend Service", "Rust + Axum", "接收 HTTP 请求，触发工作流运行 / 恢复 / 终止")

' ── Runner Library 内部组件 ─────────────────────────────────
Container_Boundary(runner, "Runner Library  (apps/runner)") {

    Component(workflow_app, "WorkflowApp", "Rust struct", "对外公开 API：run / resume / terminate / edit-session；\n持有 ConcurrencyGate，管理并发配额")

    Component(concurrency_gate, "ConcurrencyGate", "Semaphore + Mutex", "全局最大并发（默认 50）+ 每工作流最大并发（默认 5）；\nOverflowPolicy：Queue（排队等待）/ Reject（立即拒绝）")

    Component(workflow_runner, "WorkflowRunner", "Rust struct", "组装 WorkflowEngine + RunStore；\n执行后持久化 summary 与 snapshot")

    Component(workflow_engine, "WorkflowEngine", "Rust struct", "逐节点驱动执行循环；\n读取 TransitionDefinition 决定下一节点；\n调用 WorkflowRunObserver / WorkflowRunController 钩子")

    Component(executor_registry, "ExecutorRegistry", "HashMap<NodeType, Arc<dyn NodeExecutor>>", "按 NodeType 注册并分发执行器；\n支持运行时注册自定义执行器")

    ' ── 节点执行器分组 ──────────────────────────────────────
    Component(exec_trigger, "触发器节点\nstart / webhook_trigger", "NodeExecutor", "start：提取触发输入，初始化 state\nwebhook_trigger：按 mode(body/headers/full)\n提取 trigger payload 传入下游")

    Component(exec_flow, "流程控制节点\nif_else / switch", "NodeExecutor", "if_else：对 condition 表达式求值，输出 branch_key(true/false)\nswitch：对 expression 求值，匹配 case 输出对应 branch_key")

    Component(exec_data, "数据操作节点\nset_state / fetch", "NodeExecutor", "set_state：将 outputMapping 合并写入 workflow state\nfetch：发起 HTTP 请求，支持 GET/POST/…，返回 response + data")

    Component(exec_async, "异步等待节点\nwait / task / respond", "NodeExecutor", "wait：挂起，产出 NextSignal(event)，等待外部 resume\ntask：调用 TaskHandler.create()，挂起等待任务完成\nrespond：向 webhook 调用方回写 HTTP 响应，可选 terminal")

    Component(exec_compute, "计算节点\ncode", "NodeExecutor", "code：fork Node.js 子进程执行 JS/TS 脚本，\n或 rustc 编译后执行 Rust 代码\n支持 timeout + terminate 信号")

    Component(exec_sub, "子流程节点\nsub_workflow", "NodeExecutor", "内联或按 ref 解析子工作流定义；\n递归调用 WorkflowEngine.run()；\n子流程 Waiting 时产出 NextSignal 透传给父流程")

    Component(exec_end, "终止节点\nend", "NodeExecutor", "标记流程结束，输出最终 state；terminal=true")

    ' ── 公共执行契约 ────────────────────────────────────────
    Component(node_executor_trait, "NodeExecutor trait", "Rust trait", "fn execute(node, context) -> Result<NodeExecutionResult>\nNodeExecutionResult 携带：status / output / state_patch\n/ branch_key / next_signal / logs / terminal")

    Component(node_context, "NodeExecutionContext", "Rust struct", "每次节点调用的只读上下文快照：\nrun_id / workflow_key / trigger / input\n/ state / env / WorkflowRunController")

    ' ── 存储抽象 ────────────────────────────────────────────
    Component(store_catalog, "CatalogStore", "trait + PG/InMem 双实现", "存取 WorkflowDefinition；\n支持 sub_workflow ref 解析")

    Component(store_run, "RunStore", "trait + PG/InMem 双实现", "存取 WorkflowRunRecord + WorkflowRunSnapshot；\n恢复执行时读取 snapshot")

    Component(store_session, "EditSessionStore", "trait + PG/InMem 双实现", "存取编辑草稿；AI 协作写入 draft，\nFrontend 通过 SSE 实时订阅变更")

    ' ── 服务注册 ────────────────────────────────────────────
    Component(task_handler_registry, "TaskHandlerRegistry", "HashMap<String, Arc<dyn TaskHandler>>", "task 节点委托的业务处理器注册表；\n内置 mock manual_review；\n可在应用层注册领域特定 handler")

    Component(workflow_def_registry, "WorkflowDefinitionRegistry", "HashMap<String, WorkflowDefinition>", "供 sub_workflow ref 查找的内存定义注册表")
}

' ── 外部依赖 ────────────────────────────────────────────────
ContainerDb_Ext(postgres, "PostgreSQL", "数据库", "PG 实现的持久化后端")
System_Ext(node_proc, "Node.js 子进程", "code executor fork")

' ── 关系 ────────────────────────────────────────────────────
Rel(backend_api, workflow_app, "run(def, trigger, env)\nresume(run_id, signal)\nterminate(run_id)", "in-process fn call")

Rel(workflow_app, concurrency_gate, "acquire permit\n(global + per-workflow)", "Semaphore.acquire")
Rel(workflow_app, workflow_runner, "委托执行", "in-process")

Rel(workflow_runner, workflow_engine, "engine.run()\nengine.resume()", "in-process")
Rel(workflow_runner, store_run, "持久化 summary / snapshot", "in-process")

Rel(workflow_engine, executor_registry, "registry.resolve(node_type)", "in-process")
Rel(workflow_engine, node_context, "构造 NodeExecutionContext\n传入每个 executor", "in-process")

Rel(executor_registry, node_executor_trait, "调度执行", "trait dispatch")

Rel(node_executor_trait, exec_trigger, "", "")
Rel(node_executor_trait, exec_flow, "", "")
Rel(node_executor_trait, exec_data, "", "")
Rel(node_executor_trait, exec_async, "", "")
Rel(node_executor_trait, exec_compute, "", "")
Rel(node_executor_trait, exec_sub, "", "")
Rel(node_executor_trait, exec_end, "", "")

Rel(exec_data, store_catalog, "fetch 节点需要解析外部服务地址\n（通过 WorkflowServices）", "in-process")
Rel(exec_sub, workflow_def_registry, "按 ref 查找子工作流定义", "in-process")
Rel(exec_async, task_handler_registry, "task 节点 → handler.create(payload)", "in-process")
Rel(exec_compute, node_proc, "JS/TS: fork Node.js + stdin/stdout\nRust: rustc 编译临时文件后 fork binary\n+ timeout / terminate", "process")

Rel(store_catalog, postgres, "SQL", "sqlx")
Rel(store_run, postgres, "SQL", "sqlx")
Rel(store_session, postgres, "SQL", "sqlx")

note as n_result
  **NodeExecutionResult 语义**
  status=success   → 继续执行下一节点
  status=waiting   → 挂起；保存 snapshot；
                     等待 resume(run_id, signal)
  status=failed    → 触发 onError 策略或终止
  terminal=true    → 无论 status，立即结束工作流
  branch_key       → 传给 Transition.condition 决定分支
  state_patch      → merge 到全局 workflow state
  next_signal      → 异步节点产出，随 SSE 推送给前端
end note

note as n_resume
  **恢复流程（resume）**
  1. 从 RunStore 读取 WorkflowRunSnapshot
  2. snapshot 包含：currentNodeId / trigger /
     lastInput / state / timeline / lastSignal / env
  3. WorkflowEngine 从 currentNodeId 继续执行
  4. 支持手动 patch（manual-patch API）修改
     恢复时注入的 input
end note

@enduml
