@startuml runner-c4-component

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title SES Flow - Runner C4 Component Diagram

LAYOUT_LEFT_RIGHT()
LAYOUT_WITH_LEGEND()

' -- 外部调用方
Container_Ext(backend, "Backend Service", "Rust + Axum", "接收 HTTP 请求，调用 Runner 公开 API")
ContainerDb_Ext(postgres, "PostgreSQL", "数据库", "持久化工作流定义、运行记录、快照、编辑 session")
System_Ext(shell_proc, "Shell 子进程", "shell 节点 fork")
System_Ext(node_proc, "Node.js 子进程", "code 节点 fork")

' -- Runner Library
Container_Boundary(runner, "Runner Library (apps/runner)") {

    ' -- 入口层
    Component(workflow_app, "WorkflowApp", "公开 API 门面", "对外暴露 run / resume / terminate / create_edit_session / update_draft，持有 ConcurrencyGate")

    Component(concurrency_gate, "ConcurrencyGate", "Semaphore + Mutex", "全局并发上限(默认50) + 每 workflow 上限(默认5)，OverflowPolicy: Queue / Reject，队列超时默认30s")

    ' -- 执行层
    Component(workflow_runner, "WorkflowRunner", "执行协调器", "组合 WorkflowEngine + RunStore，执行后持久化 RunRecord + Snapshot")

    Component(workflow_engine, "WorkflowEngine", "核心调度引擎", "execute_from 逐节点循环，处理 run / resume / resume_sub_workflow，每步回调 Observer，检测 Controller 终止信号，内置 max_steps 保护")

    Component(executor_registry, "ExecutorRegistry", "执行器注册表", "HashMap NodeType to NodeExecutor，按节点类型分发，支持运行时注册自定义执行器")

    ' -- 节点执行器
    Component(exec_trigger, "触发器执行器 start/webhook_trigger/cron_trigger", "NodeExecutor", "start: 初始化 state，提取 trigger.body 作首个 input；webhook_trigger: 按 mode(body/headers/full) 提取 payload；cron_trigger: 按 cron 表达式定时触发，待实现")

    Component(exec_control, "流程控制执行器 if_else/switch", "NodeExecutor", "if_else: 对 condition 求值输出 branch_key true/false；switch: 匹配 expression 输出对应 branch_key")

    Component(exec_data, "数据操作执行器 set_state/fetch", "NodeExecutor", "set_state: outputMapping merge 写入全局 state；fetch: 同步 HTTP 请求，支持 method/url/headers/timeout/retry")

    Component(exec_async, "异步等待执行器 wait/task/respond", "NodeExecutor", "wait: 产出 NextSignal 挂起，恢复时校验 event+correlationKey；task: 调 TaskHandler.create()；respond: 回写 HTTP 响应，可设 terminal=true")

    Component(exec_compute, "计算执行器 code/shell", "NodeExecutor", "code: fork Node.js 子进程执行 JS；shell: fork Shell 子进程执行命令；共享 timeout 轮询 + terminate 信号检测")

    Component(exec_sub, "子流程执行器 sub_workflow", "NodeExecutor", "内联 definition 或 config.ref 两种来源，递归调用 WorkflowEngine，子流程 Waiting 时透传 NextSignal，通过 statePath 合并子 state")

    Component(exec_end, "终止执行器 end", "NodeExecutor", "标记流程结束，webhook+sync 触发器时自动生成 webhook_response NextSignal")

    ' -- 公共契约
    Component(node_executor_trait, "NodeExecutor trait", "Rust trait", "fn execute(node, ctx) -> Result<NodeExecutionResult>，所有执行器实现此接口")

    Component(node_exec_context, "NodeExecutionContext", "只读上下文快照", "run_id / workflow_key / trigger / input / state / env / WorkflowRunController 引用")

    Component(node_exec_result, "NodeExecutionResult", "执行结果信封", "status(success/waiting/failed/skipped) / output / state_patch / branch_key / next_signal / logs / terminal")

    ' -- 模板引擎
    Component(template_engine, "EvaluationContext Template", "模板解析器", "解析 trigger.x / input.x / state.x / env.x / output.x 五类路径引用，用于 inputMapping / outputMapping / config 动态值")

    ' -- 存储层
    Component(catalog_store, "WorkflowCatalogStore", "trait + PG/InMem 双实现", "存取 WorkflowDefinition，支持 sub_workflow ref 查找")

    Component(run_store, "WorkflowRunStore", "trait + PG/InMem 双实现", "存取 RunRecord + RunSnapshot，恢复时按 run_id 读取 snapshot，支持搜索分页")

    Component(session_store, "WorkflowEditSessionStore", "trait + PG/InMem 双实现", "存取编辑草稿，AI Gateway 写入 draft，Frontend 通过 SSE 订阅变更")

    ' -- 服务注册
    Component(task_handler_reg, "TaskHandlerRegistry", "业务任务处理器注册", "HashMap name to TaskHandler，task 节点委托 handler.create()，内置 mock manual_review，可注册领域 handler")

    Component(workflow_def_reg, "WorkflowDefinitionRegistry", "子流程定义注册", "HashMap key to WorkflowDefinition，sub_workflow ref 模式内存查找表")

    ' -- 观察者 & 控制器
    Component(run_observer, "WorkflowRunObserver", "运行进度钩子", "每步回调 on_summary(summary)，默认 Noop，应用层实现 SSE 推送，事件流 Running/Waiting/Completed/Failed/Terminated")

    Component(run_controller, "WorkflowRunController", "终止控制钩子", "should_terminate(run_id) -> bool，引擎每步检测，默认 Noop，应用层维护 terminate 标记集合")
}

' -- 关系：入口层
Rel_D(backend, workflow_app, "run() / resume() / terminate() / create_edit_session() / update_draft()", "in-process")
Rel_D(workflow_app, concurrency_gate, "acquire(workflow_key) / 释放 permit on drop", "Semaphore")
Rel_D(workflow_app, workflow_runner, "并发许可通过后委托执行", "in-process")

' -- 关系：执行层
Rel_D(workflow_runner, workflow_engine, "engine.run() / engine.resume()", "in-process")
Rel_D(workflow_runner, run_store, "save_record() / save_snapshot()", "in-process")
Rel_D(workflow_engine, executor_registry, "registry.resolve(node_type)", "in-process")
Rel_D(workflow_engine, node_exec_context, "构造并传入每个节点调用", "in-process")
Rel_D(workflow_engine, run_observer, "emit_summary() 每步回调", "in-process")
Rel_D(workflow_engine, run_controller, "should_terminate() 每步检测", "in-process")

' -- 关系：执行器分发
Rel_D(executor_registry, node_executor_trait, "dispatch execute(node, ctx)", "trait dyn")
Rel_D(node_executor_trait, exec_trigger, "start / webhook_trigger / cron_trigger", "")
Rel_D(node_executor_trait, exec_control, "if_else / switch", "")
Rel_D(node_executor_trait, exec_data, "set_state / fetch", "")
Rel_D(node_executor_trait, exec_async, "wait / task / respond", "")
Rel_D(node_executor_trait, exec_compute, "code / shell", "")
Rel_D(node_executor_trait, exec_sub, "sub_workflow", "")
Rel_D(node_executor_trait, exec_end, "end", "")

' -- 关系：执行器依赖
Rel(exec_control, template_engine, "condition / expression 求值", "")
Rel(exec_data, template_engine, "inputMapping / config 解析", "")
Rel(exec_async, task_handler_reg, "task_type -> handler.create()", "")
Rel(exec_sub, workflow_def_reg, "ref -> WorkflowDefinition", "")
Rel(exec_sub, workflow_engine, "递归 engine.run() / engine.resume()", "递归调用")
Rel(exec_compute, shell_proc, "fork stdin/stdout timeout/terminate", "process")
Rel(exec_compute, node_proc, "fork stdin/stdout timeout/terminate", "process")

' -- 关系：存储层
Rel_D(catalog_store, postgres, "SQL", "sqlx")
Rel_D(run_store, postgres, "SQL", "sqlx")
Rel_D(session_store, postgres, "SQL", "sqlx")
Rel(workflow_app, catalog_store, "list / get / upload workflow", "")
Rel(workflow_app, session_store, "create / get / update edit session", "")

@enduml
