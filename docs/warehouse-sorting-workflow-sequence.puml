@startuml

!include https://md-1301452398.cos.ap-nanjing.myqcloud.com/orchard/c4_plantuml/core.puml

title Webhook to Wait-and-Resume Sequence

actor Upstream as UP
participant "API Gateway / BFF" as API
participant "Workflow Engine" as ENG
participant "Definition Service" as DEF
participant "Connector Gateway" as CONN
participant "Task Service" as TASK
database "PostgreSQL" as DB
queue "Message Bus" as MQ
participant "External System / Device" as EXT

UP -> API : POST /flows/order/inbound
API -> ENG : createRun(triggerPayload)
ENG -> DEF : loadPublishedDefinition(workflowKey, scope)
DEF --> ENG : definition(version=N)
ENG -> DB : insert workflow_run
ENG -> DB : insert workflow_node_execution(start)
ENG -> CONN : execute Fetch / Action
CONN -> EXT : call OMS/RCS/Printer
EXT --> CONN : accepted / taskId
CONN --> ENG : success(output)
ENG -> DB : save state + node execution
ENG -> TASK : create task or waiting hook
TASK --> ENG : waiting(taskId / correlationKey)
ENG -> DB : insert workflow_waiting_event
ENG --> API : async_ack / runId
API --> UP : 202 Accepted

EXT -> API : callback(taskId, status)
API -> MQ : publish resume event
MQ -> ENG : resume(runId, correlationKey)
ENG -> DB : load run + waiting event + state
ENG -> DB : insert workflow_node_execution(resume)
ENG -> CONN : continue next node
CONN -> EXT : call downstream service
EXT --> CONN : success
CONN --> ENG : success
ENG -> DB : update run as succeeded
ENG --> API : final status recorded
@enduml
