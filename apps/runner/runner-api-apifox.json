{
  "openapi": "3.0.1",
  "info": {
    "title": "Runner REST API",
    "description": "Runner 工作流引擎 REST API 接口文档",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:3002",
      "description": "本地开发服务器"
    }
  ],
  "variables": {
    "workspaceId": {
      "default": "ws-runner-rest",
      "description": "工作空间 ID"
    },
    "workspaceName": {
      "default": "Runner REST Client",
      "description": "工作空间名称"
    },
    "workflowId": {
      "default": "runner-rest-demo",
      "description": "工作流 ID"
    },
    "waitRunId": {
      "default": "run-1775885937139-1",
      "description": "Wait 类型运行 ID"
    },
    "taskRunId": {
      "default": "run-1775885937139-2",
      "description": "Task 类型运行 ID"
    }
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "健康检查",
        "operationId": "health",
        "responses": {
          "200": {
            "description": "健康检查成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "ok"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/workflows": {
      "get": {
        "summary": "列出已注册 workflows",
        "operationId": "listWorkflows",
        "responses": {
          "200": {
            "description": "成功返回工作流列表",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Workflow"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "注册用于接口联调的 demo workflow",
        "operationId": "uploadDemoWorkflow",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateWorkflowRequest"
              },
              "examples": {
                "demo": {
                  "summary": "Demo 工作流",
                  "value": {
                    "workspaceId": "ws-runner-rest",
                    "workspaceName": "Runner REST Client",
                    "workflowId": "runner-rest-demo",
                    "workflow": {
                      "meta": {
                        "key": "runner.rest.demo",
                        "name": "Runner REST Demo",
                        "version": 1
                      },
                      "trigger": {
                        "type": "manual"
                      },
                      "inputSchema": {
                        "type": "object"
                      },
                      "nodes": [
                        {
                          "id": "start_1",
                          "type": "start",
                          "name": "Start"
                        },
                        {
                          "id": "mode_switch",
                          "type": "switch",
                          "name": "Mode Switch",
                          "config": {
                            "expression": "{{trigger.body.mode}}"
                          }
                        },
                        {
                          "id": "wait_callback",
                          "type": "wait",
                          "name": "Wait Callback",
                          "config": {
                            "event": "rcs.callback"
                          },
                          "inputMapping": {
                            "correlationKey": "{{trigger.headers.requestId}}",
                            "orderNo": "{{trigger.body.orderNo}}"
                          }
                        },
                        {
                          "id": "manual_review_task",
                          "type": "task",
                          "name": "Manual Review Task",
                          "config": {
                            "taskType": "manual_review",
                            "completeEvent": "task.completed"
                          },
                          "inputMapping": {
                            "orderNo": "{{trigger.body.orderNo}}",
                            "reason": "created by runner-api.http"
                          }
                        },
                        {
                          "id": "end_1",
                          "type": "end",
                          "name": "End"
                        }
                      ],
                      "transitions": [
                        {
                          "from": "start_1",
                          "to": "mode_switch"
                        },
                        {
                          "from": "mode_switch",
                          "to": "wait_callback",
                          "label": "wait",
                          "priority": 100
                        },
                        {
                          "from": "mode_switch",
                          "to": "manual_review_task",
                          "label": "task",
                          "priority": 90
                        },
                        {
                          "from": "mode_switch",
                          "to": "end_1",
                          "branchType": "default",
                          "priority": 1
                        },
                        {
                          "from": "wait_callback",
                          "to": "end_1"
                        },
                        {
                          "from": "manual_review_task",
                          "to": "end_1"
                        }
                      ],
                      "policies": {}
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "工作流创建成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "workflowId": {
                      "type": "string",
                      "example": "runner-rest-demo"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/workflows/{workflowId}": {
      "get": {
        "summary": "查询 workflow 详情",
        "operationId": "getWorkflow",
        "parameters": [
          {
            "name": "workflowId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "runner-rest-demo"
          }
        ],
        "responses": {
          "200": {
            "description": "成功返回工作流详情",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Workflow"
                }
              }
            }
          },
          "404": {
            "description": "工作流不存在"
          }
        }
      }
    },
    "/workflows/{workflowId}/run": {
      "post": {
        "summary": "启动工作流运行",
        "description": "启动一个 wait 类型或 task 类型的运行",
        "operationId": "startRun",
        "parameters": [
          {
            "name": "workflowId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "runner-rest-demo"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StartRunRequest"
              },
              "examples": {
                "wait": {
                  "summary": "Wait 类型运行",
                  "value": {
                    "trigger": {
                      "headers": {
                        "requestId": "req-rest-wait-1"
                      },
                      "body": {
                        "mode": "wait",
                        "orderNo": "SO-REST-WAIT-1"
                      }
                    },
                    "env": {
                      "tenantId": "tenant-a",
                      "warehouseId": "WH-1",
                      "operatorId": "rest-client"
                    }
                  }
                },
                "task": {
                  "summary": "Task 类型运行",
                  "value": {
                    "trigger": {
                      "headers": {
                        "requestId": "req-rest-task-1"
                      },
                      "body": {
                        "mode": "task",
                        "orderNo": "SO-REST-TASK-1"
                      }
                    }
                  }
                },
                "terminate": {
                  "summary": "用于终止的 Wait 类型运行",
                  "value": {
                    "trigger": {
                      "headers": {
                        "requestId": "req-rest-term-1"
                      },
                      "body": {
                        "mode": "wait",
                        "orderNo": "SO-REST-TERM-1"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "运行启动成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "runId": {
                      "type": "string",
                      "example": "run-1775885937139-1"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/runs/{runId}": {
      "get": {
        "summary": "查询 run 执行摘要",
        "operationId": "getRunSummary",
        "parameters": [
          {
            "name": "runId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "run-1775885937139-1"
          }
        ],
        "responses": {
          "200": {
            "description": "成功返回运行摘要",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RunSummary"
                }
              }
            }
          },
          "404": {
            "description": "运行不存在"
          }
        }
      }
    },
    "/runs/{runId}/events": {
      "get": {
        "summary": "订阅 run SSE 事件",
        "description": "手动执行后保持连接,可观察 summary 事件;恢复或终止后会继续推送更新",
        "operationId": "streamRunEvents",
        "parameters": [
          {
            "name": "runId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "run-1775885937139-1"
          }
        ],
        "responses": {
          "200": {
            "description": "SSE 事件流",
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/runs/{runId}/resume": {
      "post": {
        "summary": "恢复 run",
        "description": "event 必须匹配等待的事件类型,correlationKey 必须和等待时写入的一致",
        "operationId": "resumeRun",
        "parameters": [
          {
            "name": "runId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "run-1775885937139-1"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ResumeRunRequest"
              },
              "examples": {
                "wait_callback": {
                  "summary": "恢复 Wait 回调",
                  "value": {
                    "event": {
                      "event": "rcs.callback",
                      "correlationKey": "req-rest-wait-1",
                      "status": "done",
                      "orderNo": "SO-REST-WAIT-1",
                      "dispatchId": "dispatch-rest-1"
                    }
                  }
                },
                "task_completed": {
                  "summary": "恢复 Task 完成",
                  "value": {
                    "event": {
                      "event": "task.completed",
                      "taskId": "task-xxx",
                      "status": "approved",
                      "operatorId": "reviewer-1"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "恢复成功"
          }
        }
      }
    },
    "/runs/{runId}/terminate": {
      "post": {
        "summary": "终止 waiting run",
        "operationId": "terminateRun",
        "parameters": [
          {
            "name": "runId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "run-1775885937139-1"
          }
        ],
        "responses": {
          "200": {
            "description": "终止成功"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateWorkflowRequest": {
        "type": "object",
        "required": ["workspaceId", "workspaceName", "workflowId", "workflow"],
        "properties": {
          "workspaceId": {
            "type": "string",
            "example": "ws-runner-rest"
          },
          "workspaceName": {
            "type": "string",
            "example": "Runner REST Client"
          },
          "workflowId": {
            "type": "string",
            "example": "runner-rest-demo"
          },
          "workflow": {
            "$ref": "#/components/schemas/WorkflowDefinition"
          }
        }
      },
      "WorkflowDefinition": {
        "type": "object",
        "required": ["meta", "trigger", "nodes", "transitions"],
        "properties": {
          "meta": {
            "type": "object",
            "properties": {
              "key": {
                "type": "string",
                "example": "runner.rest.demo"
              },
              "name": {
                "type": "string",
                "example": "Runner REST Demo"
              },
              "version": {
                "type": "integer",
                "example": 1
              }
            }
          },
          "trigger": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": ["manual", "webhook", "schedule"],
                "example": "manual"
              }
            }
          },
          "inputSchema": {
            "type": "object",
            "example": {
              "type": "object"
            }
          },
          "nodes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WorkflowNode"
            }
          },
          "transitions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WorkflowTransition"
            }
          },
          "policies": {
            "type": "object",
            "example": {}
          }
        }
      },
      "WorkflowNode": {
        "type": "object",
        "required": ["id", "type", "name"],
        "properties": {
          "id": {
            "type": "string",
            "example": "start_1"
          },
          "type": {
            "type": "string",
            "enum": ["start", "end", "switch", "wait", "task"],
            "example": "start"
          },
          "name": {
            "type": "string",
            "example": "Start"
          },
          "config": {
            "type": "object",
            "example": {
              "expression": "{{trigger.body.mode}}",
              "event": "rcs.callback",
              "taskType": "manual_review",
              "completeEvent": "task.completed"
            }
          },
          "inputMapping": {
            "type": "object",
            "example": {
              "correlationKey": "{{trigger.headers.requestId}}",
              "orderNo": "{{trigger.body.orderNo}}"
            }
          }
        }
      },
      "WorkflowTransition": {
        "type": "object",
        "required": ["from", "to"],
        "properties": {
          "from": {
            "type": "string",
            "example": "start_1"
          },
          "to": {
            "type": "string",
            "example": "mode_switch"
          },
          "label": {
            "type": "string",
            "example": "wait"
          },
          "priority": {
            "type": "integer",
            "example": 100
          },
          "branchType": {
            "type": "string",
            "enum": ["default"],
            "example": "default"
          }
        }
      },
      "StartRunRequest": {
        "type": "object",
        "required": ["trigger"],
        "properties": {
          "trigger": {
            "type": "object",
            "properties": {
              "headers": {
                "type": "object",
                "example": {
                  "requestId": "req-rest-wait-1"
                }
              },
              "body": {
                "type": "object",
                "example": {
                  "mode": "wait",
                  "orderNo": "SO-REST-WAIT-1"
                }
              }
            }
          },
          "env": {
            "type": "object",
            "properties": {
              "tenantId": {
                "type": "string",
                "example": "tenant-a"
              },
              "warehouseId": {
                "type": "string",
                "example": "WH-1"
              },
              "operatorId": {
                "type": "string",
                "example": "rest-client"
              }
            }
          }
        }
      },
      "ResumeRunRequest": {
        "type": "object",
        "required": ["event"],
        "properties": {
          "event": {
            "type": "object",
            "description": "事件内容,根据不同节点类型有不同的结构"
          }
        }
      },
      "RunSummary": {
        "type": "object",
        "properties": {
          "runId": {
            "type": "string",
            "example": "run-1775885937139-1"
          },
          "status": {
            "type": "string",
            "enum": ["running", "waiting", "completed", "terminated"],
            "example": "waiting"
          },
          "currentNodeId": {
            "type": "string",
            "example": "wait_callback"
          },
          "lastSignal": {
            "type": "object",
            "properties": {
              "event": {
                "type": "string",
                "example": "task.created"
              },
              "payload": {
                "type": "object",
                "example": {
                  "taskId": "task-xxx"
                }
              }
            }
          }
        }
      },
      "Workflow": {
        "type": "object",
        "properties": {
          "workflowId": {
            "type": "string",
            "example": "runner-rest-demo"
          },
          "workspaceId": {
            "type": "string",
            "example": "ws-runner-rest"
          },
          "workspaceName": {
            "type": "string",
            "example": "Runner REST Client"
          },
          "definition": {
            "$ref": "#/components/schemas/WorkflowDefinition"
          }
        }
      }
    }
  }
}
