{
  "meta": {
    "key": "code-flow",
    "name": "Code Flow",
    "version": 1,
    "scope": {
      "tenant": "tenant-a",
      "warehouse": "WH-1"
    },
    "status": "published"
  },
  "trigger": {
    "type": "webhook",
    "path": "/flows/code",
    "responseMode": "sync"
  },
  "inputSchema": {
    "type": "object"
  },
  "nodes": [
    {
      "id": "start_1",
      "type": "start",
      "name": "Start"
    },
    {
      "id": "webhook_in",
      "type": "webhook_trigger",
      "name": "Webhook Trigger"
    },
    {
      "id": "run_code",
      "type": "code",
      "name": "Run Code",
      "inputMapping": {
        "orderNo": "{{input.orderNo}}",
        "qty": "{{input.qty}}",
        "route": "{{input.route}}",
        "requestId": "{{trigger.headers.requestId}}"
      },
      "config": {
        "language": "js",
        "source": "const quantity = params.qty == null ? 0 : Number(params.qty);\nconst branch = params.route === 'priority' ? 'priority' : 'default';\nconsole.log('code node start', { requestId: params.requestId, branch });\nreturn {\n  output: {\n    orderNo: params.orderNo,\n    normalizedQty: quantity,\n    route: params.route,\n    branch,\n    requestId: params.requestId\n  },\n  statePatch: {\n    code: {\n      orderNo: params.orderNo,\n      normalizedQty: quantity,\n      branch,\n      requestId: params.requestId,\n      tenantId: env.tenantId\n    }\n  },\n  branchKey: branch\n};"
      }
    },
    {
      "id": "mark_priority",
      "type": "set_state",
      "name": "Mark Priority",
      "config": {
        "path": "decision"
      },
      "inputMapping": {
        "value": {
          "handledBy": "priority"
        }
      }
    },
    {
      "id": "mark_default",
      "type": "set_state",
      "name": "Mark Default",
      "config": {
        "path": "decision"
      },
      "inputMapping": {
        "value": {
          "handledBy": "default"
        }
      }
    },
    {
      "id": "respond_ok",
      "type": "respond",
      "name": "Respond",
      "config": {
        "statusCode": 200
      },
      "inputMapping": {
        "orderNo": "{{state.code.orderNo}}",
        "normalizedQty": "{{state.code.normalizedQty}}",
        "branch": "{{state.code.branch}}",
        "handledBy": "{{state.decision.handledBy}}",
        "requestId": "{{state.code.requestId}}",
        "tenantId": "{{state.code.tenantId}}"
      }
    },
    {
      "id": "end_1",
      "type": "end",
      "name": "End"
    }
  ],
  "transitions": [
    {
      "from": "start_1",
      "to": "webhook_in"
    },
    {
      "from": "webhook_in",
      "to": "run_code"
    },
    {
      "from": "run_code",
      "to": "mark_priority",
      "label": "priority",
      "priority": 100
    },
    {
      "from": "run_code",
      "to": "mark_default",
      "branchType": "default",
      "priority": 1
    },
    {
      "from": "mark_priority",
      "to": "respond_ok"
    },
    {
      "from": "mark_default",
      "to": "respond_ok"
    },
    {
      "from": "respond_ok",
      "to": "end_1"
    }
  ],
  "policies": {}
}
